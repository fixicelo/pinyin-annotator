{
  "name": "pinyin-annotator",
  "displayName": "Pinyin Annotator",
  "version": "1.7.0",
  "description": "A browser extension overlays Hanyu Pinyin or Zhuyin annotations over Chinese characters present in web pages and video closed captions.",
  "author": "fixicelo <fixicelo@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fixicelo/pinyin-annotator.git"
  },
  "dependencies": {
    "@pinyin-pro/data": "^1.3.1",
    "@plasmohq/messaging": "^0.7.2",
    "@plasmohq/storage": "^1.15.0",
    "cnchar": "^3.2.6",
    "cnchar-poly": "^3.2.6",
    "cnchar-trad": "^3.2.6",
    "pinyin-pro": "^3.28.1",
    "plasmo": "^0.90.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "scripting",
      "storage",
      "contextMenus"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "pinyin-annotator@fixicelo.ext"
      }
    },
    "commands": {
      "toggle-annotation": {
        "suggested_key": {
          "default": "Alt+Shift+P",
          "mac": "Alt+Shift+P"
        },
        "description": "Toggle Pinyin annotations"
      }
    }
  }
}
